{
  "name": "browsergame",
  "version": "0.1.0",
  "private": true,
  "description": "A browser-based, top-down MMO blending the feel of WC3 / SC2 / Diablo / RuneScape.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "tunnel": "node scripts/tunnel.mjs",
    "host": "npm run build && concurrently -k -n server,tunnel -c green,cyan \"node dist/server/index.js\" \"node scripts/tunnel.mjs\"",
    "host:named": "npm run build && concurrently -k -n server,tunnel -c green,cyan \"node dist/server/index.js\" \"node scripts/named-tunnel.mjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "stress": "tsx tools/bots/stress.ts",
    "chaos": "tsx tools/bots/chaos.ts",
    "screenshot": "node scripts/screenshot.mjs",
    "gen:sprites": "tsx tools/assetgen/sprites/cli.ts",
    "gen:creatures": "tsx tools/assetgen/creatures/cli.ts",
    "gen:fx": "tsx tools/assetgen/fx/cli.ts",
    "gen:tiles": "tsx tools/assetgen/tiles/cli.ts",
    "gen:icons": "tsx tools/assetgen/icons/cli.ts",
    "gen:emitter": "tsx tools/assetgen/emitters/cli.ts",
    "gen:sfx": "tsx tools/assetgen/sfx/cli.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.5.12",
    "cloudflared": "^0.7.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
