# Copy to .env and adjust as needed. Defaults are fine for local dev.

# Port the authoritative game server (HTTP + WebSocket) listens on.
PORT=8080

# Server simulation tick rate (Hz). Higher = smoother, more CPU/bandwidth.
TICK_RATE=20

# Optional shared secret that unlocks the privileged in-game "engine" commands.
# Leave empty in dev. NEVER commit a real value — set it in .env only.
ENGINE_ADMIN_TOKEN=
