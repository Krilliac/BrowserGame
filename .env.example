# Copy to .env and adjust as needed. Defaults are fine for local dev.

# Port the authoritative game server (HTTP + WebSocket) listens on.
PORT=8080

# Server simulation tick rate (Hz). Higher = smoother, more CPU/bandwidth.
TICK_RATE=20

# Instancing strategy:
#   auto   = scale instances by player cap / load (production-style; default)
#   single = one instance per area, unlimited players, no scaling (quick testing)
INSTANCING=auto

# SQLite content database (areas, spells, items, monsters, NPCs, loot, quests). Created and
# seeded from the built-in content on first run; edit it with any SQLite tool to change the game.
GAME_DB=game.db

# Password for the seeded 'dev' account (Developer access for chat commands). Change this!
# In-game: /login dev <DEV_PASSWORD>. Defaults to an insecure value if unset.
DEV_PASSWORD=changeme

# Optional shared secret that unlocks the legacy privileged "engine" command path.
# Leave empty in dev. NEVER commit a real value — set it in .env only.
ENGINE_ADMIN_TOKEN=
